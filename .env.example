# --- OpenAI-compatible API (default) ---
OPENAI_API_KEY=
# Model id as understood by your provider (e.g. gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Optional: custom base URL (OpenAI-compatible proxy, GitHub Models, etc.)
# OPENAI_BASE_URL=

# --- Azure OpenAI (optional alternative) ---
# If set, these take precedence over OPENAI_API_KEY / OPENAI_BASE_URL
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# Deployment name used as the model id
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- ChromaDB ---
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION_NAME=research_refs

# --- Search ---
# Set to 1 to skip live web search and use bundled mock snippets only
USE_MOCK_SEARCH=0
