# Provider: openai | azure | openrouter
LLM_PROVIDER=openai

# --- OpenAI (api.openai.com) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- OpenRouter (openrouter.ai) — OpenAI-compatible API ---
# Set LLM_PROVIDER=openrouter and use an OpenRouter model id, e.g. openai/gpt-4o-mini
# OPENROUTER_API_KEY=
# Optional: site URL / app name for OpenRouter rankings (recommended by OpenRouter)
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Research Pipeline
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Azure OpenAI / Foundry ---
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional web search (Serper)
SERPER_API_KEY=
